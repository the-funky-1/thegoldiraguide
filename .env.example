# Public site URL used for canonical tags, sitemap, robots, JSON-LD, and LLM files.
NEXT_PUBLIC_SITE_URL=https://www.thegoldiraguide.com

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-01
# Read token for private Sanity datasets and preview reads.
SANITY_API_READ_TOKEN=
# Secret used by /api/revalidate webhook signature validation.
SANITY_REVALIDATE_SECRET=
# Write token for local/admin content seeding scripts only. Do not expose publicly.
SANITY_WRITE_TOKEN=

# Market data and rate limiting
METALPRICE_API_KEY=
# Optional. If omitted, spot-price API routes fall back to in-process rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Feature flag: render the live spot-price ticker in the global header
NEXT_PUBLIC_HEADER_TICKER=false

# Analytics
# GA4 measurement ID, for example G-XXXXXXXXXX.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-HQLVVS7H01
# Legacy alias also accepted by the analytics config. Prefer NEXT_PUBLIC_GA_MEASUREMENT_ID.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
# Amplitude browser SDK API key. Server zone must be US or EU.
NEXT_PUBLIC_AMPLITUDE_API_KEY=
NEXT_PUBLIC_AMPLITUDE_SERVER_ZONE=US
# Optional local/debug controls.
NEXT_PUBLIC_ANALYTICS_DEBUG=false
NEXT_PUBLIC_ANALYTICS_DISABLED=false
NEXT_PUBLIC_VERCEL_ANALYTICS_MODE=auto

# Local tooling overrides
# Used by scripts/validate-json-ld.ts when validating a running server.
BASE_URL=http://localhost:3000
# Used by Playwright webServer; defaults to 3123 if unset.
PORT=3123
